   "source": [
    "from pandas import read_csv"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "d6c62d5c",
   "metadata": {},
   "outputs": [],
   "source": [
    "data = read_csv(\n",
    "    \"../data/eistage.csv\",\n",
    "    skiprows=2,\n",
    "    names=[\"year\", \"heat\", \"ice\"],\n",
    "    usecols=[3, 5, 6],\n",
    "    sep=\";\"\n",
    ")\n",
    "data.dropna(inplace=True)\n",
    "data[\"xtrem_days\"] = data[\"heat\"] + data[\"ice\"]"
   ]
  },
